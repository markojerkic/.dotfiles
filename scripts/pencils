#!/usr/bin/env bash

if [ -d /mnt/c/ ] && command -v wslpath >/dev/null 2>&1 && command -v wslvar >/dev/null 2>&1; then
    windows_userprofile=""
    while IFS= read -r line; do
        if [[ "$line" =~ ^[A-Za-z]:\\ ]]; then
            windows_userprofile="$line"
        fi
    done < <(wslvar USERPROFILE 2>/dev/null)

    windows_profile_dir=""
    if [ -n "$windows_userprofile" ]; then
        windows_profile_dir=$(wslpath "$windows_userprofile" 2>/dev/null)
    fi

    if [ -n "$windows_profile_dir" ] && [ -d "$windows_profile_dir/AppData/Local/Packages" ]; then
        terminal_dir=$(find "$windows_profile_dir/AppData/Local/Packages/" -maxdepth 1 -type d -name "Microsoft.WindowsTerminal*")
    else
        terminal_dir=""
    fi

    settings_file="$terminal_dir/LocalState/settings.json"

    if [ -n "$terminal_dir" ] && [ -f "$settings_file" ]; then
        chmod +w "$settings_file"
        opacity=$(jq -r '.profiles.list[2].backgroundImageOpacity // 0' "$settings_file")
        temp_settings_file=$(mktemp)
        if [ "$opacity" = "0" ]; then
            jq '.profiles.list[].backgroundImageOpacity = 0.2' "$settings_file" > "$temp_settings_file"
        else
            jq '.profiles.list[].backgroundImageOpacity = 0' "$settings_file" > "$temp_settings_file"
        fi
        mv "$temp_settings_file" "$settings_file"
    else
        echo "WARNING: Windows Terminal settings.json not found"
    fi
else
    # Change line background-opacity in ~/dev/.dotfiles/.config/ghostty/config
    # Extract opacity value
    opacity=$(grep "background-opacity" ~/dev/.dotfiles/.config/ghostty/config | awk '{print $3}')
    # Ensure opacity is treated as a number
    opacity=${opacity//[^0-9.]/}
    if [ "$opacity" == "1" ]; then
        echo "Setting opacity to 0.85"
        sed -i 's/background-opacity = 1/background-opacity = 0.85/' ~/dev/.dotfiles/.config/ghostty/config
    else
        echo "Setting opacity to 1"
        sed -i 's/background-opacity = 0.85/background-opacity = 1/' ~/dev/.dotfiles/.config/ghostty/config
    fi
fi
